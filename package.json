    "@graphql-typed-document-node/core": "^3.2.0",
    "@navikt/aksel-icons": "^8.11.0",
    "@navikt/ds-css": "^8.11.0",
    "@navikt/ds-react": "^8.11.0",
    "@navikt/nav-dekoratoren-moduler": "^4.1.1",
    "@navikt/oasis": "^4.1.4",
    "@portabletext/react": "^6.2.0",
    "@react-router/fs-routes": "^7.15.1",
    "@react-router/node": "^7.15.1",
    "@react-router/serve": "^7.15.1",
    "@sanity/client": "^7.22.0",
    "classnames": "^2.5.1",
    "date-fns": "^4.3.0",
    "graphql": "^16.14.0",
    "graphql-request": "^7.4.0",
    "groq": "^5.26.0",
    "html-react-parser": "^6.1.2",
    "isbot": "^5.1.40",
    "msw": "^2.14.6",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "^7.15.1",
    "react-router-devtools": "^6.2.0",
    "tiny-invariant": "^1.3.3",
    "unleash-client": "^6.11.0",
    "uuid": "^14.0.0",
    "vite-plugin-devtools-json": "^1.0.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@graphql-codegen/cli": "7.0.0",
    "@graphql-codegen/client-preset": "^6.0.0",
    "@graphql-codegen/typescript": "6.0.1",
