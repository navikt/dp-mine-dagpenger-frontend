    "@elastic/ecs-pino-format": "^1.5.0",
    "@grafana/faro-web-sdk": "^1.19.0",
    "@grafana/faro-web-tracing": "^1.19.0",
    "@navikt/aksel-icons": "^7.40.0",
    "@navikt/ds-css": "^7.40.0",
    "@navikt/ds-react": "^7.40.0",
    "@navikt/nav-dekoratoren-moduler": "^3.7.2",
    "@navikt/oasis": "^3.8.0",
    "@portabletext/react": "^3.2.4",
    "@react-router/fs-routes": "^7.15.1",
    "@react-router/node": "^7.15.1",
    "@react-router/serve": "^7.15.1",
    "@sanity/client": "^7.22.1",
    "classnames": "^2.5.1",
    "date-fns": "^4.3.0",
    "graphql-request": "^7.4.0",
    "groq": "^3.99.0",
    "html-react-parser": "^5.2.17",
    "isbot": "^5.1.40",
    "msw": "^2.14.6",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.15.1",
    "react-router-devtools": "^6.2.0",
    "tiny-invariant": "^1.3.3",
    "unleash-client": "^6.11.0",
    "uuid": "^14.0.0",
    "vite-plugin-devtools-json": "^0.2.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.9.0",
    "@graphql-codegen/cli": "5.0.7",
    "@graphql-codegen/client-preset": "^4.8.3",
    "@graphql-codegen/typescript": "4.1.6",
    "@inquirer/prompts": "^7.10.1",
    "@portabletext/types": "^2.0.15",
    "@react-router/dev": "^7.15.1",
